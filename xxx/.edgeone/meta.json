{
  "conf": {
    "headers": [],
    "redirects": [],
    "rewrites": [],
    "caches": [],
    "has404": false,
    "ssr404": true
  },
  "has404": false,
  "frameworkRoutes": [
    {
      "regexPath": "/_nuxt/.*",
      "isStatic": true
    },
    {
      "regexPath": "/icon/.*",
      "isStatic": true
    },
    {
      "regexPath": "/tencentcloud/.*",
      "isStatic": true
    },
    {
      "regexPath": "/(about|test-ssg)(?:$|/_payload\\.json)",
      "isStatic": true
    },
    {
      "regexPath": "/(avator\\.jpg|favicon\\.ico|robots\\.txt)",
      "isStatic": true
    },
    {
      "regexPath": "/test/:id(?:$|/_payload\\.json)",
      "isStatic": true
    }
  ],
  "nodeFunctionsRoutes": [
    {
      "routePath": "/hello-node",
      "mountPath": "/",
      "method": [
        "GET",
        "POST",
        "PUT",
        "DELETE",
        "PATCH",
        "HEAD",
        "OPTIONS"
      ],
      "module": [
        "node-functions/hello-node.js:onRequest"
      ]
    }
  ],
  "edgeFunctionsRoutes": [
    {
      "routePath": "/hello-edge",
      "mountPath": "/",
      "method": [
        "GET",
        "POST",
        "PUT",
        "DELETE",
        "PATCH",
        "HEAD",
        "OPTIONS"
      ],
      "module": [
        "edge-functions/hello-edge.js:onRequest"
      ]
    }
  ]
}